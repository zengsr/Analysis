---

## 3. `.gitignore`

```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
env/
.env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Jupyter
.ipynb_checkpoints/

# Data files (too large for git)
data/*.csv
data/*.data
data/*.txt
data/*.gz
!data/.gitkeep

# Outputs (regeneratable)
outputs/figures/*.png
outputs/figures/*.pdf
outputs/*.pkl
outputs/*.joblib
!outputs/figures/.gitkeep

# OS
.DS_Store
Thumbs.db

# LaTeX auxiliary
reports/*.aux
reports/*.log
reports/*.out
reports/*.toc
reports/*.synctex.gz
reports/*.fls
reports/*.fdb_latexmk
